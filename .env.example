# Server
PORT=5000
NODE_ENV=development
API_CORS_ORIGINS=https://your-production-domain.com

# Commusoft API
COMMUSOFT_COMPANY_ID=14377
COMMUSOFT_USERNAME=
COMMUSOFT_PASSWORD=
COMMUSOFT_API_KEY=

# Twilio SMS
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/client_portal

# OpenAI (for virtual engineer chat - optional, falls back to keyword responses)
OPENAI_API_KEY=
